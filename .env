DATABASE_DSN=postgres://my_user:my_pass@localhost:5432/my_db
MSG_TOPIC=messages
MSG_FILTERED_BLOCK_USERS_TOPIC=MESSAGES_FILTERED_BLOCK_USERS_STREAM
SCHEMA_REGISTRY_URL=http://127.0.0.1:8081
KAFKA_BROKERS=localhost:9093,localhost:9094,localhost:9095
KAFKA_MSG_GROUP=msg_group
KAFKA_SESSION_TIMEOUT_MS=6000
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_CONSUMER_PULL_TIMEOUT_MS=100
KAFKA_ACKS=all
